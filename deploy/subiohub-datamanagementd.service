[Unit]
Description=SubioHub Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=subiohub
Group=subiohub
WorkingDirectory=/opt/subiohub
ExecStart=/opt/subiohub/datamanagementd \
  -socket-path /tmp/subiohub-datamanagement.sock \
  -sqlite-path /var/lib/subiohub/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
